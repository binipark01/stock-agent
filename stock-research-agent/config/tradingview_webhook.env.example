# Copy this to config/tradingview_webhook.env and change the secret.
TRADINGVIEW_WEBHOOK_SECRET=change-me
TRADINGVIEW_WEBHOOK_HOST=0.0.0.0
TRADINGVIEW_WEBHOOK_PORT=8765

# Optional: command receives webhook response JSON on stdin.
# Reuse the existing Hermes Telegram bot/token without copying secrets.
# In WSL, prefer Telegram IPv4 fallback to avoid slow/failed api.telegram.org IPv6/DNS route.
# TRADINGVIEW_WEBHOOK_NOTIFY_TIMEOUT=60
# TRADINGVIEW_WEBHOOK_NOTIFY_COMMAND='TELEGRAM_ENV_FILE=/mnt/c/Users/PSB/AppData/Local/hermes/.env TELEGRAM_FALLBACK_IPS=149.154.166.110,149.154.167.220 TELEGRAM_PREFER_FALLBACK_IPS=1 TELEGRAM_NOTIFY_TIMEOUT=10 python3 scripts/send_telegram_from_json.py'

# Optional cloudflared path. If empty, scripts search PATH and tools/cloudflared.
# CLOUDFLARED_BIN=
